NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ordersystem?schema=public
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=kafka:9092
ACCESS_TOKEN_SECRET=super-secret-access-token
REFRESH_TOKEN_SECRET=super-secret-refresh-token
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
AUTH_SERVICE_URL=http://auth-service:4001
ORDER_SERVICE_URL=http://order-service:4002
NOTIFICATION_SERVICE_URL=http://notification-service:4004
PROCESSING_SERVICE_URL=http://processing-service:4003
GATEWAY_URL=http://gateway:4000
OUTBOX_POLL_INTERVAL_MS=2000
PROCESSING_DELAY_MS=5000
PROCESSING_RETRY_MAX=3
PROCESSING_LOCK_TTL_MS=15000
SOCKET_EVENTS_CHANNEL=ws:user-events
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
VITE_API_BASE_URL=
PORT=4000
